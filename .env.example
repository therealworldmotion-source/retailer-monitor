# ─── Required ──────────────────────────────────────────────
# Get from @BotFather on Telegram — create a fresh bot for the online monitor.
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (numeric). Use @userinfobot to find it.
TELEGRAM_CHAT_ID=

# ─── Optional ──────────────────────────────────────────────
# Skip specific retailers (comma-separated keys).
# Known retailer keys: otakume,virgin_megastore,legends_own_the_game,colorland_toys,magrudy,zgames,geekay,little_things
# Geekay is already disabled in the main loop (needs headful Chrome) — no action needed.
DISABLED_RETAILERS=

# Path for persistent state. On Railway, attach a volume and set this to its mount path (e.g. /data).
DATA_DIR=/data

# ─── Auto-checkout (Legends Own The Game) ──────────────────
# Set to "true" to enable auto-checkout. Requires the fields below.
LEGENDS_AUTO_CHECKOUT=false

# Semicolon-separated list of exact product titles to auto-buy.
# Example: "Ascended Heroes Pin Collection;First Partner Booster Collection"
LEGENDS_WATCHLIST=

CHECKOUT_EMAIL=
CHECKOUT_NAME=
CHECKOUT_PHONE=
CHECKOUT_ADDRESS=
CHECKOUT_CITY=
CHECKOUT_STATE=
CHECKOUT_ZIP=
